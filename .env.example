# ── Pax Americana (Rust) — environment configuration ───────────────────────────
# Copy to `.env` (or set as real environment variables) on each machine.
# Both apps connect DIRECTLY to an IB Gateway (recommended) or TWS over the socket
# API. IB Gateway is headless and far more stable for 24/7 servers.
#
# Port reference:
#   IB Gateway   live = 4001   paper = 4002
#   TWS          live = 7496   paper = 7497

# ── MASTER (pax-master) ─────────────────────────────────────────────────────────
# IB endpoint the master connects to (its own local Gateway/TWS).
PAX_IB_HOST=127.0.0.1
PAX_IB_PORT=4002
# clientId 0 sees ALL manually-placed orders/positions in the session.
PAX_IB_CLIENT_ID=0
# Address the master's HTTP API binds to. Open this TCP port in the firewall.
PAX_HTTP_BIND=0.0.0.0:5001
# How often the master refreshes positions + balance from IB (seconds).
PAX_REFRESH_SECS=5

# ── CLIENT (pax-client) ─────────────────────────────────────────────────────────
# Base URL of the master's HTTP API (the master server's public IP + port).
PAX_MASTER_URL=http://YOUR_MASTER_IP:5001
# This client's own IB endpoint.
PAX_IB_HOST=127.0.0.1
PAX_IB_PORT_LIVE=4001
PAX_IB_PORT_PAPER=4002
# Seconds between reconciliation passes.
PAX_SYNC_SECS=10
# After ordering a symbol, suppress new orders for it this long (lets fills settle).
PAX_ORDER_COOLDOWN_SECS=20

# ── SHARED SECRET (both apps) ───────────────────────────────────────────────────
# When set on the master, clients MUST send the same value. Strongly recommended
# whenever the master is reachable on a public IP.
PAX_API_KEY=

import { ScrollView, ListView } from "std-widgets.slint";

struct PortRow {
    symbol: string,
    qty: string,
    avg: string,
    last: string,
    value: string,
    pnl: string,
    up: bool,
}

struct TradeRow {
    date: string,
    symbol: string,
    side: string,
    qty: string,
    entry: string,
    exit_p: string,
    pnl: string,
    ret: string,
    sector: string,
    up: bool,
}

struct MetricRow {
    label: string,
    value: string,
}

struct Candle {
    cx: float,     // center x (0..100)
    bw: float,     // body width (0..100)
    high_y: float, // wick top (0..100, 0 = top)
    low_y: float,  // wick bottom
    top_y: float,  // body top
    bot_y: float,  // body bottom
    up: bool,
}

component LineField inherits Rectangle {
    in-out property <string> value;
    height: 28px;
    background: #0d1420;
    border-radius: 6px;
    border-width: 1px;
    border-color: #222d40;
    TextInput {
        x: 8px;
        width: parent.width - 16px;
        height: 100%;
        vertical-alignment: center;
        color: #e9f0fb;
        font-size: 14px;
        text <=> root.value;
    }
}

component Segment inherits Rectangle {
    in property <bool> active;
    in property <string> label;
    callback clicked;
    height: 28px;
    background: root.active ? #34445e : #0d1420;
    border-radius: 6px;
    border-width: 1px;
    border-color: #222d40;
    TouchArea { clicked => { root.clicked(); } }
    Text {
        text: root.label;
        color: root.active ? white : #909fb7;
        horizontal-alignment: center;
        vertical-alignment: center;
        font-weight: 700;
    }
}

component PaxButton inherits Rectangle {
    in property <string> label;
    in property <color> fill: #ff7849;
    callback clicked;
    height: 32px;
    border-radius: 8px;
    background: ta.has-hover ? root.fill.brighter(15%) : root.fill;
    ta := TouchArea { clicked => { root.clicked(); } }
    Text {
        text: root.label;
        color: #06080d;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

export component ClientWindow inherits Window {
    title: "Pax Americana - Client";
    default-font-size: 14px;
    preferred-width: 760px;
    preferred-height: 820px;
    min-width: 620px;
    min-height: 620px;
    background: #0a0e16;

    in property <bool> connected;
    in property <bool> running;
    in property <string> status_text: "Stopped";
    in property <string> balance_text: "Net Liquidation: -";
    in property <string> server_text: "Server: -";
    in property <string> counts_text;
    in property <string> margin_text;
    in property <bool> margin_blocked;
    in property <string> log_text;

    in-out property <int> active_tab;      // 0 sync, 1 portfolio, 2 charts
    in-out property <int> account_mode;    // 0 live, 1 paper
    in-out property <int> trade_mode;      // 0 long&short, 1 long only
    in-out property <int> exec_mode;       // 0 existing+new, 1 new only
    in-out property <int> hours_mode;      // 0 = 24h, 1 = regular trading hours only
    in-out property <string> multiplier;
    in-out property <string> drawdown;
    in-out property <string> max_notional;
    in-out property <string> max_qty;
    in-out property <string> host;
    in-out property <string> live_port;
    in-out property <string> paper_port;
    in-out property <string> account;
    in property <[string]> accounts;

    in property <string> update_text;
    in property <bool> update_available;

    // Portfolio
    in property <[PortRow]> portfolio;
    in property <string> port_total;
    in property <string> port_pnl;
    in property <bool> port_pnl_up;
    in property <bool> data_connected;

    // Charts
    in-out property <string> chart_symbol;
    in-out property <int> chart_tf;        // 0 1D, 1 1W, 2 1M, 3 6M, 4 1Y
    in property <string> chart_status;
    in property <[Candle]> candles;
    in property <float> chart_min_val;
    in property <float> chart_max_val;
    in property <string> chart_min;
    in property <string> chart_max;
    in property <string> chart_last;
    in property <bool> chart_up;
    in property <bool> avg_present;
    in property <float> avg_y;
    in property <string> avg_label;
    in property <bool> has_trade_markers;
    in property <float> entry_marker_y;
    in property <float> exit_marker_y;
    in property <string> trade_entry_label;
    in property <string> trade_exit_label;

    // Flex
    in-out property <string> flex_token;
    in-out property <string> flex_query_id;
    in property <string> flex_status;

    // Trades
    in property <[TradeRow]> trades;
    in property <string> trades_summary;

    // Performance
    in-out property <int> perf_curve_mode;
    in property <[MetricRow]> perf_metrics;
    in property <image> equity_img;
    in property <image> drawdown_img;
    in property <image> histogram_img;
    in property <image> pie_side_img;
    in property <image> pie_sector_img;
    in property <image> pie_winloss_img;
    in property <image> symbol_bar_img;
    in property <image> monthly_img;
    in property <string> perf_summary;
    in property <string> export_status;
    in-out property <bool> show_equity: true;
    in-out property <bool> show_drawdown: true;
    in-out property <bool> show_histogram: true;
    in-out property <bool> show_pies: true;
    in-out property <bool> show_symbol_bar: true;
    in-out property <bool> show_monthly: true;

    callback start();
    callback stop();
    callback close_all();
    callback save();
    callback kill();
    callback check_update();
    callback download_update();
    callback detect_accounts();
    callback load_chart();
    callback view_symbol(string);
    callback chart_drag_begin();
    callback chart_drag_to(length, length); // (delta-x from press, plot width)
    callback chart_scroll(bool);            // true = forward in time
    callback chart_zoom(bool);              // true = zoom in
    callback fetch_flex();
    callback view_trade(int);
    callback export_pdf();
    callback recompute_perf();

    VerticalLayout {
        padding: 16px;
        spacing: 8px;

        // ── Header (always visible) ──────────────────────────────────────────
        HorizontalLayout {
            spacing: 8px;
            Text { text: "⬢ PAX AMERICANA"; color: #ff7849; font-size: 20px; font-weight: 800; }
            Text { text: "CLIENT"; color: #3d8af7; font-size: 13px; font-weight: 700; vertical-alignment: center; }
            Rectangle { }
            Text {
                text: root.status_text;
                color: root.connected ? #34d399 : #fb5d6e;
                font-weight: 700;
                vertical-alignment: center;
            }
        }
        Rectangle { height: 1px; background: #222d40; }
        HorizontalLayout {
            spacing: 24px;
            Text { text: root.balance_text; color: #34d399; font-weight: 700; }
            Text { text: root.server_text; color: #53b9f2; }
        }

        // ── Tab bar ──────────────────────────────────────────────────────────
        HorizontalLayout {
            spacing: 6px;
            Segment { label: "Sync"; active: root.active_tab == 0; width: 80px; clicked => { root.active_tab = 0; } }
            Segment { label: "Portfolio"; active: root.active_tab == 1; width: 90px; clicked => { root.active_tab = 1; } }
            Segment { label: "Charts"; active: root.active_tab == 2; width: 80px; clicked => { root.active_tab = 2; } }
            Segment { label: "Trades"; active: root.active_tab == 3; width: 80px; clicked => { root.active_tab = 3; } }
            Segment { label: "Perf"; active: root.active_tab == 4; width: 70px; clicked => { root.active_tab = 4; } }
            Rectangle { }
        }

        // ════════════════════════ SYNC TAB ════════════════════════
        if root.active_tab == 0 : VerticalLayout {
            vertical-stretch: 1;
            spacing: 8px;

            Text { text: root.counts_text; color: #909fb7; }
            Text {
                text: root.margin_text;
                color: root.margin_blocked ? #f5b454 : #5a6880;
                font-size: 12px;
            }

            Text { text: "ENGINE"; color: #909fb7; font-size: 11px; font-weight: 700; }
            HorizontalLayout {
                spacing: 10px;
                PaxButton { label: root.running ? "▶ RUNNING" : "▶ START"; fill: #34d399; width: 120px; clicked => { root.start(); } }
                PaxButton { label: "■ STOP"; fill: #fb5d6e; width: 100px; clicked => { root.stop(); } }
                PaxButton { label: "CLOSE ALL"; fill: #f5b454; width: 120px; clicked => { root.close_all(); } }
                PaxButton { label: "KILL OTHERS"; fill: #c97a3f; width: 130px; clicked => { root.kill(); } }
                Rectangle { }
            }

            Text { text: "SETTINGS"; color: #909fb7; font-size: 11px; font-weight: 700; }
            HorizontalLayout {
                spacing: 8px;
                Text { text: "Account"; color: #909fb7; width: 70px; vertical-alignment: center; }
                Segment { label: "Live"; active: root.account_mode == 0; width: 70px; clicked => { root.account_mode = 0; } }
                Segment { label: "Paper"; active: root.account_mode == 1; width: 70px; clicked => { root.account_mode = 1; } }
                Rectangle { width: 12px; }
                Text { text: "Trading"; color: #909fb7; width: 60px; vertical-alignment: center; }
                Segment { label: "Long & Short"; active: root.trade_mode == 0; width: 110px; clicked => { root.trade_mode = 0; } }
                Segment { label: "Long Only"; active: root.trade_mode == 1; width: 100px; clicked => { root.trade_mode = 1; } }
                Rectangle { }
            }
            HorizontalLayout {
                spacing: 8px;
                Text { text: "Execution"; color: #909fb7; width: 70px; vertical-alignment: center; }
                Segment { label: "Existing + New"; active: root.exec_mode == 0; width: 130px; clicked => { root.exec_mode = 0; } }
                Segment { label: "New Only"; active: root.exec_mode == 1; width: 100px; clicked => { root.exec_mode = 1; } }
                Rectangle { width: 12px; }
                Text { text: "Hours"; color: #909fb7; width: 46px; vertical-alignment: center; }
                Segment { label: "24h"; active: root.hours_mode == 0; width: 60px; clicked => { root.hours_mode = 0; } }
                Segment { label: "RTH only"; active: root.hours_mode == 1; width: 90px; clicked => { root.hours_mode = 1; } }
                Rectangle { }
            }
            HorizontalLayout {
                spacing: 8px;
                Text { text: "Multiplier x"; color: #909fb7; width: 90px; vertical-alignment: center; }
                LineField { value <=> root.multiplier; width: 80px; }
                Text { text: "Max Drawdown %"; color: #909fb7; width: 120px; vertical-alignment: center; }
                LineField { value <=> root.drawdown; width: 80px; }
                Rectangle { }
            }
            HorizontalLayout {
                spacing: 8px;
                Text { text: "Max Pos $"; color: #909fb7; width: 90px; vertical-alignment: center; }
                LineField { value <=> root.max_notional; width: 110px; }
                Text { text: "Max Pos Qty"; color: #909fb7; width: 110px; vertical-alignment: center; }
                LineField { value <=> root.max_qty; width: 110px; }
                Rectangle { }
            }
            HorizontalLayout {
                spacing: 8px;
                Text { text: "IB Host"; color: #909fb7; width: 90px; vertical-alignment: center; }
                LineField { value <=> root.host; width: 160px; }
                Text { text: "Live"; color: #909fb7; width: 32px; vertical-alignment: center; }
                LineField { value <=> root.live_port; width: 80px; }
                Text { text: "Paper"; color: #909fb7; width: 44px; vertical-alignment: center; }
                LineField { value <=> root.paper_port; width: 80px; }
                Rectangle { }
            }
            HorizontalLayout {
                spacing: 6px;
                Text { text: "Account"; color: #909fb7; width: 90px; vertical-alignment: center; }
                for a in root.accounts : Rectangle {
                    min-width: 100px;
                    height: 28px;
                    background: a == root.account ? #34445e : #0d1420;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: a == root.account ? #ff7849 : #222d40;
                    TouchArea { clicked => { root.account = a; } }
                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        Text { text: a; color: a == root.account ? white : #909fb7; vertical-alignment: center; font-weight: 700; }
                    }
                }
                Rectangle {
                    width: 130px;
                    height: 28px;
                    border-radius: 6px;
                    background: dt.has-hover ? #202c3e : #172130;
                    border-width: 1px;
                    border-color: #222d40;
                    dt := TouchArea { clicked => { root.detect_accounts(); } }
                    Text { text: "Detect Accounts"; color: #909fb7; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                }
                Rectangle { }
            }
            if root.accounts.length == 0 : Text {
                text: "No accounts detected — set host/port/mode, then Detect Accounts.";
                color: #5a6880;
                font-size: 11px;
            }
            HorizontalLayout {
                spacing: 10px;
                PaxButton { label: "SAVE SETTINGS"; width: 160px; clicked => { root.save(); } }
                Text { text: "Modes/risk apply live; host & ports apply on START."; color: #5a6880; font-size: 11px; vertical-alignment: center; }
            }

            HorizontalLayout {
                spacing: 8px;
                Text {
                    text: root.update_text;
                    color: root.update_available ? #f5b454 : #5a6880;
                    font-size: 12px;
                    vertical-alignment: center;
                }
                Rectangle { }
                if root.update_available : Rectangle {
                    width: 110px;
                    height: 26px;
                    border-radius: 7px;
                    background: dl.has-hover ? #3ee0a6 : #34d399;
                    dl := TouchArea { clicked => { root.download_update(); } }
                    Text { text: "UPDATE NOW"; color: #06080d; font-weight: 700; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                }
                Rectangle {
                    width: 140px;
                    height: 26px;
                    border-radius: 7px;
                    background: ck.has-hover ? #202c3e : #172130;
                    border-width: 1px;
                    border-color: #222d40;
                    ck := TouchArea { clicked => { root.check_update(); } }
                    Text { text: "Check for Updates"; color: #909fb7; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                }
            }

            Text { text: "LIVE ORDER FEED"; color: #909fb7; font-size: 11px; font-weight: 700; }
            Rectangle {
                vertical-stretch: 1;
                background: #0d1420;
                border-radius: 8px;
                border-width: 1px;
                border-color: #222d40;
                ScrollView {
                    VerticalLayout {
                        padding: 8px;
                        Text {
                            text: root.log_text;
                            color: #cfe3ff;
                            font-family: "Consolas";
                            font-size: 12px;
                            wrap: word-wrap;
                        }
                    }
                }
            }
        }

        // ════════════════════════ PORTFOLIO TAB ════════════════════════
        if root.active_tab == 1 : VerticalLayout {
            vertical-stretch: 1;
            spacing: 8px;

            HorizontalLayout {
                spacing: 24px;
                Text { text: "Market Value: " + root.port_total; color: #e9f0fb; font-weight: 700; }
                Text { text: "Unrealized P&L: " + root.port_pnl; color: root.port_pnl_up ? #34d399 : #fb5d6e; font-weight: 700; }
                Rectangle { }
                Text {
                    text: root.data_connected ? "● data live" : "○ data offline";
                    color: root.data_connected ? #34d399 : #5a6880;
                    font-size: 12px;
                    vertical-alignment: center;
                }
            }

            // Column header
            Rectangle {
                height: 26px;
                background: #11192a;
                border-radius: 6px;
                HorizontalLayout {
                    padding-left: 10px;
                    padding-right: 10px;
                    spacing: 8px;
                    Text { text: "Symbol"; color: #909fb7; font-size: 11px; font-weight: 700; width: 90px; vertical-alignment: center; }
                    Text { text: "Qty"; color: #909fb7; font-size: 11px; font-weight: 700; width: 80px; horizontal-alignment: right; vertical-alignment: center; }
                    Text { text: "Avg"; color: #909fb7; font-size: 11px; font-weight: 700; width: 90px; horizontal-alignment: right; vertical-alignment: center; }
                    Text { text: "Last"; color: #909fb7; font-size: 11px; font-weight: 700; width: 90px; horizontal-alignment: right; vertical-alignment: center; }
                    Text { text: "Mkt Value"; color: #909fb7; font-size: 11px; font-weight: 700; width: 130px; horizontal-alignment: right; vertical-alignment: center; }
                    Text { text: "Unrl P&L"; color: #909fb7; font-size: 11px; font-weight: 700; horizontal-alignment: right; vertical-alignment: center; }
                }
            }

            Rectangle {
                vertical-stretch: 1;
                background: #0d1420;
                border-radius: 8px;
                border-width: 1px;
                border-color: #222d40;
                if root.portfolio.length == 0 : Text {
                    x: 12px; y: 12px;
                    text: root.data_connected
                        ? "No open positions in this account."
                        : "Connecting to IB for portfolio data…";
                    color: #5a6880;
                    font-size: 12px;
                }
                ListView {
                    for r in root.portfolio : Rectangle {
                        height: 30px;
                        background: rta.has-hover ? #1b2942 : transparent;
                        rta := TouchArea { clicked => { root.view_symbol(r.symbol); } }
                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 8px;
                            Text { text: r.symbol; color: #cfe3ff; font-weight: 700; width: 90px; vertical-alignment: center; }
                            Text { text: r.qty; color: #aab8d0; width: 80px; horizontal-alignment: right; vertical-alignment: center; }
                            Text { text: r.avg; color: #aab8d0; width: 90px; horizontal-alignment: right; vertical-alignment: center; }
                            Text { text: r.last; color: #aab8d0; width: 90px; horizontal-alignment: right; vertical-alignment: center; }
                            Text { text: r.value; color: #e9f0fb; width: 130px; horizontal-alignment: right; vertical-alignment: center; }
                            Text { text: r.pnl; color: r.up ? #34d399 : #fb5d6e; horizontal-alignment: right; vertical-alignment: center; }
                        }
                    }
                }
            }
            Text { text: "Tip: click a position to chart it."; color: #5a6880; font-size: 11px; }
        }

        // ════════════════════════ CHARTS TAB ════════════════════════
        if root.active_tab == 2 : VerticalLayout {
            vertical-stretch: 1;
            spacing: 8px;

            HorizontalLayout {
                spacing: 6px;
                Text { text: "Symbol"; color: #909fb7; width: 52px; vertical-alignment: center; }
                LineField { value <=> root.chart_symbol; width: 100px; }
                PaxButton { label: "LOAD"; width: 64px; clicked => { root.load_chart(); } }
                Rectangle { width: 4px; }
                Segment { label: "M1";  active: root.chart_tf == 0; width: 38px; clicked => { root.chart_tf = 0; root.load_chart(); } }
                Segment { label: "M5";  active: root.chart_tf == 1; width: 38px; clicked => { root.chart_tf = 1; root.load_chart(); } }
                Segment { label: "M15"; active: root.chart_tf == 2; width: 42px; clicked => { root.chart_tf = 2; root.load_chart(); } }
                Segment { label: "M30"; active: root.chart_tf == 3; width: 42px; clicked => { root.chart_tf = 3; root.load_chart(); } }
                Segment { label: "H1";  active: root.chart_tf == 4; width: 36px; clicked => { root.chart_tf = 4; root.load_chart(); } }
                Segment { label: "H4";  active: root.chart_tf == 5; width: 36px; clicked => { root.chart_tf = 5; root.load_chart(); } }
                Segment { label: "D1";  active: root.chart_tf == 6; width: 36px; clicked => { root.chart_tf = 6; root.load_chart(); } }
                Segment { label: "W1";  active: root.chart_tf == 7; width: 36px; clicked => { root.chart_tf = 7; root.load_chart(); } }
                Segment { label: "MN";  active: root.chart_tf == 8; width: 38px; clicked => { root.chart_tf = 8; root.load_chart(); } }
                Rectangle { }
            }
            Text { text: root.chart_status; color: #909fb7; font-size: 12px; }

            Rectangle {
                vertical-stretch: 1;
                background: #0d1420;
                border-radius: 8px;
                border-width: 1px;
                border-color: #222d40;
                clip: true;

                // Right-edge price axis labels.
                Text { x: parent.width - 64px; y: 8px; text: root.chart_max; color: #5a6880; font-size: 11px; }
                Text { x: parent.width - 64px; y: parent.height - 20px; text: root.chart_min; color: #5a6880; font-size: 11px; }
                Text {
                    x: 12px; y: 8px;
                    text: root.chart_last;
                    color: root.chart_up ? #34d399 : #fb5d6e;
                    font-size: 13px;
                    font-weight: 700;
                }

                // Plot area (inset; leaves room for the right price axis).
                plot := Rectangle {
                    x: 8px; y: 28px;
                    width: parent.width - 70px;
                    height: parent.height - 44px;
                    clip: true;

                    property <float> cursor_price:
                        root.chart_max_val - (cross.mouse-y / self.height) * (root.chart_max_val - root.chart_min_val);

                    // Average-cost line for the open position.
                    if root.avg_present : Rectangle {
                        x: 0;
                        width: 100%;
                        y: parent.height * (root.avg_y / 100) - 1px;
                        height: 2px;
                        background: #f5b454;
                    }
                    if root.avg_present : Text {
                        x: 4px;
                        y: parent.height * (root.avg_y / 100) - 14px;
                        text: root.avg_label;
                        color: #f5b454;
                        font-size: 11px;
                        font-weight: 700;
                    }

                    // Trade entry/exit markers.
                    if root.has_trade_markers : Rectangle {
                        x: 0; width: 100%;
                        y: parent.height * (root.entry_marker_y / 100) - 1px;
                        height: 2px;
                        background: #3d8af7;
                    }
                    if root.has_trade_markers : Text {
                        x: 4px;
                        y: parent.height * (root.entry_marker_y / 100) - 14px;
                        text: root.trade_entry_label;
                        color: #3d8af7;
                        font-size: 11px;
                        font-weight: 700;
                    }
                    if root.has_trade_markers : Rectangle {
                        x: 0; width: 100%;
                        y: parent.height * (root.exit_marker_y / 100) - 1px;
                        height: 2px;
                        background: #ff7849;
                    }
                    if root.has_trade_markers : Text {
                        x: 4px;
                        y: parent.height * (root.exit_marker_y / 100) + 2px;
                        text: root.trade_exit_label;
                        color: #ff7849;
                        font-size: 11px;
                        font-weight: 700;
                    }

                    // Candlesticks.
                    for c in root.candles : Rectangle {
                        // wick
                        Rectangle {
                            x: parent.width * (c.cx / 100) - 0.5px;
                            y: parent.height * (c.high_y / 100);
                            width: 1px;
                            height: max(1px, parent.height * ((c.low_y - c.high_y) / 100));
                            background: c.up ? #34d399 : #fb5d6e;
                        }
                        // body
                        Rectangle {
                            x: parent.width * ((c.cx - c.bw / 2) / 100);
                            y: parent.height * (c.top_y / 100);
                            width: max(1px, parent.width * (c.bw / 100));
                            height: max(1px, parent.height * ((c.bot_y - c.top_y) / 100));
                            background: c.up ? #34d399 : #fb5d6e;
                        }
                    }

                    // Keyboard zoom (= in, - out); focused when the plot is clicked.
                    fs := FocusScope {
                        width: 0px;
                        height: 0px;
                        key-pressed(e) => {
                            if (e.text == "=" || e.text == "+") {
                                root.chart_zoom(true);
                                return EventResult.accept;
                            }
                            if (e.text == "-" || e.text == "_") {
                                root.chart_zoom(false);
                                return EventResult.accept;
                            }
                            return EventResult.reject;
                        }
                    }

                    // Crosshair + price readout on hover; drag to pan, scroll to slide.
                    cross := TouchArea {
                        property <length> press_x;
                        pointer-event(e) => {
                            if (e.kind == PointerEventKind.down) {
                                fs.focus();
                                self.press_x = self.mouse-x;
                                root.chart_drag_begin();
                            }
                        }
                        moved => {
                            if (self.pressed) {
                                root.chart_drag_to(self.mouse-x - self.press_x, parent.width);
                            }
                        }
                        scroll-event(e) => {
                            root.chart_scroll(e.delta-y < 0px);
                            return EventResult.accept;
                        }
                    }
                    if cross.has-hover : Rectangle {
                        x: cross.mouse-x; width: 1px; height: 100%; background: #ffffff40;
                    }
                    if cross.has-hover : Rectangle {
                        y: cross.mouse-y; width: 100%; height: 1px; background: #ffffff40;
                    }
                    if cross.has-hover : Rectangle {
                        x: parent.width - self.width;
                        y: cross.mouse-y - 9px;
                        width: 58px; height: 18px;
                        background: #11192a;
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: #2a3a55;
                        Text {
                            text: round(plot.cursor_price * 100) / 100;
                            color: #e9f0fb;
                            font-size: 11px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                if root.candles.length == 0 : Text {
                    x: 12px; y: 32px;
                    text: "Enter a symbol and press LOAD (US stocks, SMART routing).";
                    color: #5a6880;
                    font-size: 12px;
                }
            }
        }

        // ════════════════════════ TRADES TAB ════════════════════════
        if root.active_tab == 3 : VerticalLayout {
            vertical-stretch: 1;
            spacing: 8px;

            Text { text: "IBKR FLEX WEB SERVICE"; color: #909fb7; font-size: 11px; font-weight: 700; }
            HorizontalLayout {
                spacing: 8px;
                Text { text: "Token"; color: #909fb7; width: 48px; vertical-alignment: center; }
                LineField { value <=> root.flex_token; width: 200px; }
                Text { text: "Query ID"; color: #909fb7; width: 62px; vertical-alignment: center; }
                LineField { value <=> root.flex_query_id; width: 120px; }
                PaxButton { label: "FETCH"; fill: #3d8af7; width: 80px; clicked => { root.fetch_flex(); } }
                Rectangle { }
            }
            Text { text: root.flex_status; color: #909fb7; font-size: 12px; }

            Text { text: "TRADE HISTORY"; color: #909fb7; font-size: 11px; font-weight: 700; }
            Text { text: root.trades_summary; color: #5a6880; font-size: 12px; }

            Rectangle {
                height: 26px;
                background: #11192a;
                border-radius: 6px;
                HorizontalLayout {
                    padding-left: 10px;
                    padding-right: 10px;
                    spacing: 6px;
                    Text { text: "Date"; color: #909fb7; font-size: 10px; font-weight: 700; width: 80px; vertical-alignment: center; }
                    Text { text: "Symbol"; color: #909fb7; font-size: 10px; font-weight: 700; width: 70px; vertical-alignment: center; }
                    Text { text: "Side"; color: #909fb7; font-size: 10px; font-weight: 700; width: 50px; vertical-alignment: center; }
                    Text { text: "Qty"; color: #909fb7; font-size: 10px; font-weight: 700; width: 60px; horizontal-alignment: right; vertical-alignment: center; }
                    Text { text: "Entry"; color: #909fb7; font-size: 10px; font-weight: 700; width: 70px; horizontal-alignment: right; vertical-alignment: center; }
                    Text { text: "Exit"; color: #909fb7; font-size: 10px; font-weight: 700; width: 70px; horizontal-alignment: right; vertical-alignment: center; }
                    Text { text: "P&L"; color: #909fb7; font-size: 10px; font-weight: 700; width: 80px; horizontal-alignment: right; vertical-alignment: center; }
                    Text { text: "Ret%"; color: #909fb7; font-size: 10px; font-weight: 700; width: 60px; horizontal-alignment: right; vertical-alignment: center; }
                    Text { text: "Sector"; color: #909fb7; font-size: 10px; font-weight: 700; vertical-alignment: center; }
                }
            }

            Rectangle {
                vertical-stretch: 1;
                background: #0d1420;
                border-radius: 8px;
                border-width: 1px;
                border-color: #222d40;
                if root.trades.length == 0 : Text {
                    x: 12px; y: 12px;
                    text: "No trades loaded. Enter your IBKR Flex token and Query ID, then click FETCH.";
                    color: #5a6880;
                    font-size: 12px;
                }
                ListView {
                    for r[i] in root.trades : Rectangle {
                        height: 28px;
                        background: trade_ta.has-hover ? #1b2942 : transparent;
                        trade_ta := TouchArea { clicked => { root.view_trade(i); } }
                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 6px;
                            Text { text: r.date; color: #aab8d0; font-size: 11px; width: 80px; vertical-alignment: center; }
                            Text { text: r.symbol; color: #cfe3ff; font-weight: 700; font-size: 11px; width: 70px; vertical-alignment: center; }
                            Text { text: r.side; color: r.side == "Long" ? #34d399 : #fb5d6e; font-size: 11px; width: 50px; vertical-alignment: center; }
                            Text { text: r.qty; color: #aab8d0; font-size: 11px; width: 60px; horizontal-alignment: right; vertical-alignment: center; }
                            Text { text: r.entry; color: #aab8d0; font-size: 11px; width: 70px; horizontal-alignment: right; vertical-alignment: center; }
                            Text { text: r.exit_p; color: #aab8d0; font-size: 11px; width: 70px; horizontal-alignment: right; vertical-alignment: center; }
                            Text { text: r.pnl; color: r.up ? #34d399 : #fb5d6e; font-size: 11px; width: 80px; horizontal-alignment: right; vertical-alignment: center; }
                            Text { text: r.ret; color: r.up ? #34d399 : #fb5d6e; font-size: 11px; width: 60px; horizontal-alignment: right; vertical-alignment: center; }
                            Text { text: r.sector; color: #5a6880; font-size: 10px; vertical-alignment: center; }
                        }
                    }
                }
            }
            Text { text: "Tip: click a trade to chart it."; color: #5a6880; font-size: 11px; }
        }

        // ════════════════════════ PERFORMANCE TAB ════════════════════════
        if root.active_tab == 4 : VerticalLayout {
            vertical-stretch: 1;
            spacing: 6px;

            HorizontalLayout {
                spacing: 10px;
                Text { text: "PERFORMANCE LAB"; color: #909fb7; font-size: 11px; font-weight: 700; }
                Rectangle { }
                Segment { label: "NAV"; active: root.perf_curve_mode == 0; width: 60px; clicked => { root.perf_curve_mode = 0; root.recompute_perf(); } }
                Segment { label: "Returns"; active: root.perf_curve_mode == 1; width: 80px; clicked => { root.perf_curve_mode = 1; root.recompute_perf(); } }
                PaxButton { label: "EXPORT PDF"; fill: #3d8af7; width: 120px; clicked => { root.export_pdf(); } }
            }
            Text { text: root.perf_summary; color: #5a6880; font-size: 12px; }
            Text { text: root.export_status; color: #909fb7; font-size: 11px; }

            ScrollView {
                VerticalLayout {
                    spacing: 8px;

                    if root.show_equity : Image {
                        source: root.equity_img;
                        min-height: 200px;
                        image-fit: contain;
                    }

                    if root.show_drawdown : Image {
                        source: root.drawdown_img;
                        min-height: 140px;
                        image-fit: contain;
                    }

                    Rectangle {
                        background: #0d1420;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: #222d40;
                        VerticalLayout {
                            padding: 10px;
                            spacing: 2px;
                            Text { text: "METRICS"; color: #909fb7; font-size: 11px; font-weight: 700; }
                            for m in root.perf_metrics : HorizontalLayout {
                                height: 20px;
                                Text { text: m.label; color: #909fb7; font-size: 12px; width: 180px; vertical-alignment: center; }
                                Text { text: m.value; color: #e9f0fb; font-size: 12px; font-weight: 700; vertical-alignment: center; }
                            }
                        }
                    }

                    if root.show_histogram : Image {
                        source: root.histogram_img;
                        min-height: 200px;
                        image-fit: contain;
                    }

                    if root.show_pies : HorizontalLayout {
                        spacing: 4px;
                        Image { source: root.pie_side_img; horizontal-stretch: 1; min-height: 200px; image-fit: contain; }
                        Image { source: root.pie_sector_img; horizontal-stretch: 1; min-height: 200px; image-fit: contain; }
                        Image { source: root.pie_winloss_img; horizontal-stretch: 1; min-height: 200px; image-fit: contain; }
                    }

                    if root.show_symbol_bar : Image {
                        source: root.symbol_bar_img;
                        min-height: 200px;
                        image-fit: contain;
                    }

                    if root.show_monthly : Image {
                        source: root.monthly_img;
                        min-height: 200px;
                        image-fit: contain;
                    }

                    Text { text: "INCLUDE IN REPORT"; color: #909fb7; font-size: 11px; font-weight: 700; }
                    HorizontalLayout {
                        spacing: 8px;
                        Segment { label: root.show_equity ? "☑ Equity" : "☐ Equity"; active: root.show_equity; width: 90px; clicked => { root.show_equity = !root.show_equity; } }
                        Segment { label: root.show_drawdown ? "☑ DD" : "☐ DD"; active: root.show_drawdown; width: 70px; clicked => { root.show_drawdown = !root.show_drawdown; } }
                        Segment { label: root.show_histogram ? "☑ Hist" : "☐ Hist"; active: root.show_histogram; width: 80px; clicked => { root.show_histogram = !root.show_histogram; } }
                        Segment { label: root.show_pies ? "☑ Pies" : "☐ Pies"; active: root.show_pies; width: 80px; clicked => { root.show_pies = !root.show_pies; } }
                        Segment { label: root.show_symbol_bar ? "☑ Syms" : "☐ Syms"; active: root.show_symbol_bar; width: 80px; clicked => { root.show_symbol_bar = !root.show_symbol_bar; } }
                        Segment { label: root.show_monthly ? "☑ Month" : "☐ Month"; active: root.show_monthly; width: 80px; clicked => { root.show_monthly = !root.show_monthly; } }
                        Rectangle { }
                    }
                }
            }
        }
    }
}
